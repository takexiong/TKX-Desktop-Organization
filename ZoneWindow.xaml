<Window x:Class="DesktopOrganizer.ZoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面分区"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MinWidth="80"
        MinHeight="80"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Border x:Name="RootBorder"
            CornerRadius="8"
            BorderThickness="1.5"
            BorderBrush="#66FFFFFF"
            Background="#66101828"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏：大部分区域用于拖动；名称仅左侧一小块，双击才改名 -->
            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="#99152030"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="8,0,6,0" LastChildFill="True">
                    <Button x:Name="CloseButton"
                            DockPanel.Dock="Right"
                            Content="×"
                            Width="26"
                            Height="26"
                            FontSize="16"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            ToolTip="删除分区"/>
                    <Button x:Name="LockButton"
                            DockPanel.Dock="Right"
                            Content="锁"
                            Width="28"
                            Height="26"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,2,0"
                            Click="LockButton_Click"
                            ToolTip="锁定窗口（锁定后不可拖动/缩放）"/>
                    <ComboBox x:Name="SizeCombo"
                              DockPanel.Dock="Right"
                              Width="52"
                              Height="24"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"
                              SelectedIndex="1"
                              SelectionChanged="SizeCombo_SelectionChanged"
                              ToolTip="图标尺寸：小 / 中 / 大">
                        <ComboBoxItem Content="小"/>
                        <ComboBoxItem Content="中"/>
                        <ComboBoxItem Content="大"/>
                    </ComboBox>

                    <!-- 左侧窄标题：平时显示文字，双击才进入编辑 -->
                    <Grid DockPanel.Dock="Left"
                          Width="88"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          ToolTip="双击修改名称">
                        <TextBlock x:Name="TitleText"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MouseLeftButtonDown="TitleText_MouseLeftButtonDown"/>
                        <TextBox x:Name="TitleBox"
                                 Visibility="Collapsed"
                                 Background="#33101828"
                                 BorderThickness="1"
                                 BorderBrush="#66FFFFFF"
                                 Foreground="White"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Padding="2,1"
                                 CaretBrush="White"
                                 MaxLength="20"
                                 TextChanged="TitleBox_TextChanged"
                                 LostFocus="TitleBox_LostFocus"
                                 KeyDown="TitleBox_KeyDown"/>
                    </Grid>

                    <!-- 中间空白专供拖动 -->
                    <Border Background="Transparent"/>
                </DockPanel>
            </Border>

            <!-- 图标区域 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6">
                <WrapPanel x:Name="IconPanel"
                           Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- 边缘缩放热区（锁定后禁用） -->
            <Grid x:Name="ResizeLayer" Grid.RowSpan="2">
                <Rectangle Width="6" HorizontalAlignment="Left" Fill="Transparent"
                           Cursor="SizeWE" Tag="W"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Width="6" HorizontalAlignment="Right" Fill="Transparent"
                           Cursor="SizeWE" Tag="E"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Height="6" VerticalAlignment="Top" Fill="Transparent"
                           Cursor="SizeNS" Tag="N"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Height="6" VerticalAlignment="Bottom" Fill="Transparent"
                           Cursor="SizeNS" Tag="S"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Top"
                           Fill="Transparent" Cursor="SizeNWSE" Tag="NW"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top"
                           Fill="Transparent" Cursor="SizeNESW" Tag="NE"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Width="12" Height="12" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Fill="Transparent" Cursor="SizeNESW" Tag="SW"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
                <Rectangle Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Fill="Transparent" Cursor="SizeNWSE" Tag="SE"
                           MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                           MouseMove="Resize_MouseMove"
                           MouseLeftButtonUp="Resize_MouseLeftButtonUp"/>
            </Grid>
        </Grid>
    </Border>
</Window>

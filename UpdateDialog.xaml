<Window x:Class="DesktopOrganizer.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Icon="pack://application:,,,/app.ico"
        Height="460"
        Width="460"
        MinHeight="360"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F4F7FB"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="TitleText"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A2433"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="VersionText"
                       Margin="0,6,0,0"
                       Foreground="#5A6A7A"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                BorderBrush="#D8E0EA"
                BorderThickness="1"
                Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="更新内容"
                           FontWeight="SemiBold"
                           Foreground="#1A2433"
                           Margin="0,0,0,8"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesText"
                               Foreground="#4A5A6A"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <ProgressBar x:Name="DownloadProgress"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="ProgressText"
                       Margin="0,6,0,0"
                       Foreground="#5A6A7A"
                       FontSize="12"
                       Visibility="Collapsed"/>
        </StackPanel>

        <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="False">
            <Button x:Name="CancelButton"
                    DockPanel.Dock="Right"
                    Content="稍后"
                    Padding="14,7"
                    Margin="8,0,0,0"
                    Cursor="Hand"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button x:Name="ConfirmButton"
                    DockPanel.Dock="Right"
                    Content="确认更新"
                    Padding="14,7"
                    Cursor="Hand"
                    Click="ConfirmButton_Click"
                    IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#2F6FED"
                                CornerRadius="6"
                                Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#255AD1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E4BB0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#9BB6E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DockPanel>
    </Grid>
</Window>
